#!/usr/bin/env bash
# lw — Linear Worktree
# Usage:
#   lw                          — create a scratch worktree with a random name
#   lw [<branch>|--current]     — create a scratch worktree, branching off <branch> or current
#   lw <TICKET-ID>              — create worktree + tmux window for a ticket
#   lw <TICKET-ID> <branch>     — create worktree, branching off <branch> instead of default
#   lw <TICKET-ID> --current    — create worktree, branching off the current branch
#   lw done <TICKET-ID|name>    — tear down worktree, branch, and tmux window
#   lw review <branch>          — pull a branch into a worktree for review
#   lw done review <branch>     — tear down a review worktree

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────────────────
WORKTREE_HOME="${WORKTREE_HOME:-$HOME/.superclaude}"   # where worktrees live
LINEAR_API_KEY="${LINEAR_API_KEY:-}"                    # set in env or here
# ─────────────────────────────────────────────────────────────────────────────

# ── Helpers ──────────────────────────────────────────────────────────────────
die()  { echo "error: $*" >&2; exit 1; }
info() { echo "▸ $*" >&2; }

require() {
  for cmd in "$@"; do
    command -v "$cmd" &>/dev/null || die "'$cmd' is required but not installed."
  done
}

# Generate a random silly_name1_silly_name2 branch name
generate_silly_name() {
  local adjectives=(
    blazing cosmic dancing electric fuzzy gentle happy jolly keen lazy
    mighty noble odd peaceful quirky rapid silent turbo vivid witty
    amber bronze crimson dusty emerald frosty golden hollow icy jade
  )
  local nouns=(
    badger cobra dolphin eagle falcon gecko hawk iguana jackal koala
    lemur moose narwhal otter parrot quail raven squid toucan urchin
    anvil beacon comet dagger ember flute geyser harpoon iris jetpack
  )
  local a1="${adjectives[$((RANDOM % ${#adjectives[@]}))]}"
  local n1="${nouns[$((RANDOM % ${#nouns[@]}))]}"
  echo "${a1}_${n1}"
}

# Run hook scripts from ~/.lw/<phase>/ (global) and .lw/<phase>/ (repo) in sorted order.
# Scripts are named like s10foo.sh, s50bar.sh to control execution order.
# Global hooks run first, then repo-local hooks.
# Exported env vars: LW_WORKTREE_DIR, LW_BRANCH, LW_TICKET, LW_REPO_NAME, LW_ACTION,
#                    LW_TMUX_WINDOW (set if running inside tmux)
run_hooks() {
  local phase="$1"  # "setup" or "teardown"
  local global_dir="$HOME/.lw/$phase"
  local repo_dir="$GIT_ROOT/.lw/$phase"

  local scripts=()
  for hook_dir in "$global_dir" "$repo_dir"; do
    [[ -d "$hook_dir" ]] || continue
    while IFS= read -r -d '' f; do
      scripts+=("$f")
    done < <(find "$hook_dir" -maxdepth 1 -type f -executable -print0 | sort -z)
  done

  [[ ${#scripts[@]} -gt 0 ]] || return 0

  export LW_WORKTREE_DIR="${WORKTREE_DIR:-}"
  export LW_BRANCH="${BRANCH:-}"
  export LW_TICKET="${TICKET:-}"
  export LW_REPO_NAME="${REPO_NAME:-}"
  export LW_ACTION="$phase"
  export LW_TMUX_WINDOW="${TMUX_WINDOW_NAME:-}"

  for script in "${scripts[@]}"; do
    info "Running $phase hook: $(basename "$script")…"
    (cd "${WORKTREE_DIR:-.}" && "$script") || die "Hook $(basename "$script") failed (exit $?)."
  done
}

# ── Route subcommands ─────────────────────────────────────────────────────────
# (no-arg case falls through to the create-worktree section below)

# ══════════════════════════════════════════════════════════════════════════════
# lw review <branch> — pull a branch into a worktree for review
# ══════════════════════════════════════════════════════════════════════════════
if [[ "${1:-}" == "review" ]]; then
  [[ $# -eq 2 ]] || die "Usage: lw review <branch>"
  BRANCH="$2"
  require git

  GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not inside a git repository."
  REPO_NAME="$(basename "$GIT_ROOT")"

  # ── Verify the branch exists locally or on origin — bail if neither ───────
  LOCAL_EXISTS=false
  REMOTE_EXISTS=false

  git show-ref --verify --quiet "refs/heads/$BRANCH"           2>/dev/null && LOCAL_EXISTS=true  || true
  git fetch origin "$BRANCH" 2>/dev/null                                    && REMOTE_EXISTS=true || true
  git show-ref --verify --quiet "refs/remotes/origin/$BRANCH"  2>/dev/null && REMOTE_EXISTS=true || true

  if ! $LOCAL_EXISTS && ! $REMOTE_EXISTS; then
    die "Branch '$BRANCH' not found locally or on origin."
  fi

  # Ensure a local tracking branch exists
  if ! $LOCAL_EXISTS; then
    info "Creating local branch '$BRANCH' from origin…"
    git branch "$BRANCH" "origin/$BRANCH"
  fi

  # ── Derive a filesystem-safe dir name from the branch ─────────────────────
  # e.g. "feature/auth-redesign" → "review-feature-auth-redesign"
  SAFE_BRANCH="review-${BRANCH//\//-}"
  WORKTREE_DIR="$WORKTREE_HOME/$REPO_NAME/$SAFE_BRANCH"

  mkdir -p "$(dirname "$WORKTREE_DIR")"

  if [[ -d "$WORKTREE_DIR" ]]; then
    info "Worktree already exists at $WORKTREE_DIR"
  else
    info "Creating review worktree at $WORKTREE_DIR…"
    git worktree add "$WORKTREE_DIR" "$BRANCH"
    info "Done."
  fi

  # ── tmux: open a new window for the review ────────────────────────────────
  TMUX_WINDOW_NAME=""
  if [[ -n "${TMUX:-}" ]]; then
    TMUX_WINDOW_NAME="[${REPO_NAME}] review: ${BRANCH}"
    TMUX_WINDOW_NAME="${TMUX_WINDOW_NAME:0:50}"

    EXISTING=$(tmux list-windows -F '#{window_name}' 2>/dev/null \
      | grep -Fx "$TMUX_WINDOW_NAME" || true)

    if [[ -n "$EXISTING" ]]; then
      info "tmux window '$TMUX_WINDOW_NAME' already exists — switching to it…"
      tmux select-window -t "$TMUX_WINDOW_NAME"
    else
      info "Creating tmux window '$TMUX_WINDOW_NAME'…"
      tmux new-window -c "$WORKTREE_DIR" -n "$TMUX_WINDOW_NAME"
    fi
  fi

  # ── Run setup hooks ──────────────────────────────────────────────────────
  TICKET="" run_hooks setup

  echo "$WORKTREE_DIR"
  exit 0
fi

# ══════════════════════════════════════════════════════════════════════════════
# lw done [review] <TICKET-ID|branch> — teardown
# ══════════════════════════════════════════════════════════════════════════════
if [[ "${1:-}" == "done" ]]; then
  require git
  GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not inside a git repository."
  REPO_NAME="$(basename "$GIT_ROOT")"

  IS_REVIEW=false
  if [[ "${2:-}" == "review" ]]; then
    IS_REVIEW=true
    [[ $# -eq 3 ]] || die "Usage: lw done review <branch>"
    BRANCH="$3"
    SAFE_DIR="review-${BRANCH//\//-}"
    WINDOW_PREFIX="[${REPO_NAME}] review:"
  else
    [[ $# -eq 2 ]] || die "Usage: lw done <TICKET-ID|name>"
    BRANCH=""   # resolved from worktree below
    ARG="$2"
    if [[ "$ARG" =~ ^[A-Za-z]+-[0-9]+ ]]; then
      TICKET="${ARG^^}"
      SAFE_DIR="${TICKET/\//-}"
    else
      # Scratch worktree name (e.g. fuzzy_cobra)
      TICKET=""
      SAFE_DIR="$ARG"
    fi
    WINDOW_PREFIX="[${REPO_NAME}] ${SAFE_DIR}"
  fi
  WORKTREE_DIR="$WORKTREE_HOME/$REPO_NAME/$SAFE_DIR"

  # ── Resolve branch name from the worktree (no API call needed) ────────────
  if [[ -d "$WORKTREE_DIR" ]]; then
    BRANCH=$(git -C "$WORKTREE_DIR" symbolic-ref --short HEAD 2>/dev/null || true)
  fi

  # ── Warn about uncommitted changes ────────────────────────────────────────
  if [[ -d "$WORKTREE_DIR" ]]; then
    DIRTY=$(git -C "$WORKTREE_DIR" status --porcelain 2>/dev/null || true)
    if [[ -n "$DIRTY" ]]; then
      echo "warning: worktree has uncommitted changes:" >&2
      git -C "$WORKTREE_DIR" status --short >&2
      read -r -p "Continue with teardown anyway? [y/N] " CONFIRM
      [[ "${CONFIRM,,}" == "y" ]] || { info "Aborted."; exit 0; }
    fi
  fi

  # ── Warn about unpushed commits (skip for review — it's read-only) ────────
  if ! $IS_REVIEW && [[ -n "$BRANCH" && -d "$WORKTREE_DIR" ]]; then
    LOCAL=$(git -C "$WORKTREE_DIR" rev-parse HEAD 2>/dev/null || true)
    REMOTE=$(git -C "$WORKTREE_DIR" rev-parse "origin/$BRANCH" 2>/dev/null || true)
    if [[ -n "$LOCAL" && -n "$REMOTE" && "$LOCAL" != "$REMOTE" ]]; then
      echo "warning: branch '$BRANCH' has commits not pushed to origin." >&2
      read -r -p "Continue with teardown anyway? [y/N] " CONFIRM
      [[ "${CONFIRM,,}" == "y" ]] || { info "Aborted."; exit 0; }
    fi
  fi

  # ── Resolve the tmux window name (needed by hooks and for closing) ───────
  TMUX_WINDOW_NAME=""
  TMUX_WINDOW_INDEX=""
  if [[ -n "${TMUX:-}" ]]; then
    read -r TMUX_WINDOW_INDEX TMUX_WINDOW_NAME < <(
      tmux list-windows -F '#{window_index} #{window_name}' 2>/dev/null \
        | awk -v t="$WINDOW_PREFIX" '$0 ~ t { print $1, substr($0, index($0,$2)); exit }'
    ) || true
  fi

  # ── Run teardown hooks ────────────────────────────────────────────────────
  run_hooks teardown

  # ── Remove the worktree ───────────────────────────────────────────────────
  if [[ -d "$WORKTREE_DIR" ]]; then
    info "Removing worktree at $WORKTREE_DIR…"
    git worktree remove --force "$WORKTREE_DIR"
    git worktree prune 2>/dev/null || true
  else
    info "No worktree found at $WORKTREE_DIR — skipping."
  fi

  # ── Delete the local branch ───────────────────────────────────────────────
  # For reviews, only delete if it didn't exist before (i.e. we fetched it)
  if [[ -n "$BRANCH" ]] && git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    if $IS_REVIEW; then
      # Only remove if there's no other worktree using this branch
      IN_USE=$(git worktree list --porcelain 2>/dev/null \
        | awk '/^branch / { print $2 }' \
        | grep -Fx "refs/heads/$BRANCH" || true)
      if [[ -z "$IN_USE" ]]; then
        info "Deleting local branch '$BRANCH'…"
        git branch -D "$BRANCH"
      else
        info "Branch '$BRANCH' still in use by another worktree — leaving it."
      fi
    else
      info "Deleting local branch '$BRANCH'…"
      git branch -D "$BRANCH"
    fi
  fi

  # ── Close the tmux window ─────────────────────────────────────────────────
  if [[ -n "${TMUX:-}" ]]; then
    if [[ -n "$TMUX_WINDOW_INDEX" ]]; then
      info "Closing tmux window $TMUX_WINDOW_INDEX…"
      tmux kill-window -t "$TMUX_WINDOW_INDEX"
    else
      info "No tmux window found matching '$WINDOW_PREFIX'."
    fi
  fi

  info "Done. ${BRANCH:-$SAFE_DIR} torn down."
  exit 0
fi

# ══════════════════════════════════════════════════════════════════════════════
# lw [TICKET-ID] [<branch>|--current] — create worktree
# ══════════════════════════════════════════════════════════════════════════════
[[ $# -le 2 ]] || die "Usage: lw [<TICKET-ID>] [<branch>|--current]"

# Must be run from inside a git repo
require git
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not inside a git repository."
REPO_NAME="$(basename "$GIT_ROOT")"

# ── Determine if first arg is a ticket ID or a branch/flag ───────────────────
# Ticket IDs look like PREFIX-123 (letters, dash, digits).
# Everything else is treated as a branch arg for scratch mode.
TICKET=""
BASE_BRANCH=""
SCRATCH=false

if [[ $# -eq 0 ]]; then
  SCRATCH=true
elif [[ $# -eq 1 ]]; then
  if [[ "$1" == "--current" ]]; then
    SCRATCH=true
    BASE_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null) \
      || die "Could not determine current branch (detached HEAD?)."
    info "Using current branch '$BASE_BRANCH' as base."
  elif [[ "$1" =~ ^[A-Za-z]+-[0-9]+ ]]; then
    TICKET="${1^^}"
  else
    # Treat as a branch name for scratch mode
    SCRATCH=true
    BASE_BRANCH="$1"
    info "Using '$BASE_BRANCH' as base branch."
  fi
elif [[ $# -eq 2 ]]; then
  TICKET="${1^^}"
  if [[ "$2" == "--current" ]]; then
    BASE_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null) \
      || die "Could not determine current branch (detached HEAD?)."
    info "Using current branch '$BASE_BRANCH' as base."
  else
    BASE_BRANCH="$2"
    info "Using '$BASE_BRANCH' as base branch."
  fi
fi

if $SCRATCH; then
  # ── Scratch mode: random name, no Linear ─────────────────────────────────
  SILLY_NAME=$(generate_silly_name)
  BRANCH="$SILLY_NAME"
  TITLE="scratch"
  SAFE_LABEL="$SILLY_NAME"

  info "Creating scratch worktree '$SILLY_NAME'…"

  # ── Resolve base branch ──────────────────────────────────────────────────
  if [[ -z "$BASE_BRANCH" ]]; then
    BASE_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
      | sed 's|refs/remotes/origin/||') || BASE_BRANCH=""

    if [[ -z "$BASE_BRANCH" ]]; then
      git fetch origin 2>/dev/null || true
      for candidate in main master trunk develop; do
        if git show-ref --verify --quiet "refs/remotes/origin/$candidate"; then
          BASE_BRANCH="$candidate"
          break
        fi
      done
    fi

    [[ -n "$BASE_BRANCH" ]] \
      || die "Could not determine the default branch. Set it with: git remote set-head origin --auto"
  fi

  # Ensure the base branch exists locally
  if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
    git fetch origin "$BASE_BRANCH":"$BASE_BRANCH" 2>/dev/null \
      || die "Base branch '$BASE_BRANCH' not found locally or on origin."
  fi

  info "Creating '$BRANCH' off '$BASE_BRANCH'…"
  git branch "$BRANCH" "$BASE_BRANCH"

else
  # ── Ticket mode: fetch from Linear ───────────────────────────────────────
  require curl jq
  [[ -n "$LINEAR_API_KEY" ]] || die "LINEAR_API_KEY is not set. Export it or hardcode it in this script."

  info "Fetching branch for $TICKET from Linear…"

  QUERY=$(cat <<EOF
{ "query": "{ issue(id: \"$TICKET\") { branchName title } }" }
EOF
  )

  RESPONSE=$(curl -s \
    -H "Authorization: $LINEAR_API_KEY" \
    -H "Content-Type: application/json" \
    -d "$QUERY" \
    "https://api.linear.app/graphql")

  API_ERROR=$(echo "$RESPONSE" | jq -r '.errors[0].message // empty')
  [[ -z "$API_ERROR" ]] || die "Linear API error: $API_ERROR"

  BRANCH=$(echo "$RESPONSE" | jq -r '.data.issue.branchName // empty')
  TITLE=$(echo  "$RESPONSE" | jq -r '.data.issue.title // empty')

  [[ -n "$BRANCH" ]] || die "Could not find a branch for ticket $TICKET. Check the ticket ID and your API key."

  info "Found: \"$TITLE\""
  info "Branch: $BRANCH"

  SAFE_LABEL="${TICKET/\//-}"

  # ── Ensure the branch exists locally (fetch or create off base) ──────────
  if ! git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    if [[ -z "$BASE_BRANCH" ]] && git fetch origin "$BRANCH":"$BRANCH" 2>/dev/null; then
      info "Fetched '$BRANCH' from origin."
    else
      if [[ -n "$BASE_BRANCH" ]]; then
        if ! git show-ref --verify --quiet "refs/heads/$BASE_BRANCH"; then
          git fetch origin "$BASE_BRANCH":"$BASE_BRANCH" 2>/dev/null \
            || die "Base branch '$BASE_BRANCH' not found locally or on origin."
        fi
        info "Creating '$BRANCH' off '$BASE_BRANCH'…"
        git branch "$BRANCH" "$BASE_BRANCH"
      else
        info "Branch not found on origin — detecting default branch…"
        DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
          | sed 's|refs/remotes/origin/||') || DEFAULT_BRANCH=""

        if [[ -z "$DEFAULT_BRANCH" ]]; then
          git fetch origin 2>/dev/null || true
          for candidate in main master trunk develop; do
            if git show-ref --verify --quiet "refs/remotes/origin/$candidate"; then
              DEFAULT_BRANCH="$candidate"
              break
            fi
          done
        fi

        [[ -n "$DEFAULT_BRANCH" ]] \
          || die "Could not determine the default branch. Set it with: git remote set-head origin --auto"

        info "Creating '$BRANCH' off '$DEFAULT_BRANCH'…"
        git fetch origin "$DEFAULT_BRANCH":"$DEFAULT_BRANCH" 2>/dev/null || true
        git branch "$BRANCH" "$DEFAULT_BRANCH"
      fi
    fi
  fi
fi

git show-ref --verify --quiet "refs/heads/$BRANCH" \
  || die "Branch '$BRANCH' could not be created."

# ── Create worktree ───────────────────────────────────────────────────────────
WORKTREE_DIR="$WORKTREE_HOME/$REPO_NAME/$SAFE_LABEL"

mkdir -p "$(dirname "$WORKTREE_DIR")"

if [[ -d "$WORKTREE_DIR" ]]; then
  info "Worktree already exists at $WORKTREE_DIR"
else
  info "Creating worktree at $WORKTREE_DIR…"
  git worktree add "$WORKTREE_DIR" "$BRANCH"
  info "Done."
fi

# ── tmux: create a new window, name it, and switch to it ─────────────────────
TMUX_WINDOW_NAME=""
if [[ -n "${TMUX:-}" ]]; then
  TMUX_WINDOW_NAME="[${REPO_NAME}] ${SAFE_LABEL}: ${TITLE}"
  TMUX_WINDOW_NAME="${TMUX_WINDOW_NAME:0:50}"

  EXISTING=$(tmux list-windows -F '#{window_name}' 2>/dev/null \
    | grep -Fx "$TMUX_WINDOW_NAME" || true)

  if [[ -n "$EXISTING" ]]; then
    info "tmux window '$TMUX_WINDOW_NAME' already exists — switching to it…"
    tmux select-window -t "$TMUX_WINDOW_NAME"
  else
    info "Creating tmux window '$TMUX_WINDOW_NAME'…"
    tmux new-window -c "$WORKTREE_DIR" -n "$TMUX_WINDOW_NAME"
  fi
fi

# ── Run setup hooks ───────────────────────────────────────────────────────────
run_hooks setup

echo "$WORKTREE_DIR"
